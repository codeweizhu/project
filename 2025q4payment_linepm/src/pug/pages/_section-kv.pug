- var tigerBG = []
- tigerBG.push({bg: "images/kv/card-bg-01.png", bgAlt: "卡片背景01", tiger: "images/kv/tiger/tiger-01.svg", tigerAlt: "老虎01"})
- tigerBG.push({bg: "images/kv/card-bg-02.png", bgAlt: "卡片背景02", tiger: "images/kv/tiger/tiger-02.svg", tigerAlt: "老虎02"})
- tigerBG.push({bg: "images/kv/card-bg-03.png", bgAlt: "卡片背景03", tiger: "images/kv/tiger/tiger-03.svg", tigerAlt: "老虎03"})
- tigerBG.push({bg: "images/kv/card-bg-04.png", bgAlt: "卡片背景04", tiger: "images/kv/tiger/tiger-04.svg", tigerAlt: "老虎04"})
- tigerBG.push({bg: "images/kv/card-bg-05.png", bgAlt: "卡片背景05", tiger: "images/kv/tiger/tiger-05.svg", tigerAlt: "老虎05"})
