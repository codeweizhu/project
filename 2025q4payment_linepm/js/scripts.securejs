// =============FAQ常見問題手風琴打開功能(只能允許展開一個)=================//
document.querySelectorAll(".section-faq__toggle").forEach(function (btn) {
  btn.addEventListener("click", function () {
    var target = document.querySelector(btn.dataset.target);
    var expanded = btn.getAttribute("aria-expanded") === "true";

    // 先把其他手風琴收回
    document.querySelectorAll(".section-faq__toggle").forEach(function (otherBtn) {
      if (otherBtn !== btn) {
        var otherTarget = document.querySelector(otherBtn.dataset.target);
        otherBtn.setAttribute("aria-expanded", "false");
        otherTarget.style.maxHeight = 0;
      }
    });

    // 切換當前手風琴
    btn.setAttribute("aria-expanded", !expanded);
    if (!expanded) {
      target.style.maxHeight = target.scrollHeight + "px";
    } else {
      target.style.maxHeight = 0;
    }
  });
});


