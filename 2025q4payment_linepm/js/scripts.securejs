// ===============================notice開關============================//
$('.notice__toggle').click(function (e) {
  e.preventDefault();
  $('.section-notice__container').slideDown();
  $('.notice__toggle').toggleClass('active');
  $('.notice__icon').toggleClass('active');
  if (!$('.notice__toggle').hasClass('active')) {
    var isSmallScreen = $(window).width() <= 768;
    if (isSmallScreen) {
      window.scrollTo({
        top: $('.section-notice').offset().top - 50,
        behavior: "smooth" //
      });
    } else {
      $('html, body').animate({
        scrollTop: $('.section-notice').offset().top - 50
      }, 0);
    }
    $('.section-notice__container').slideUp();
  }
});


