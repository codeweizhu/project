// ======================輪播Info Carousel============================//
document.addEventListener('DOMContentLoaded', function () {
  //splide
  var splide = new Splide('.splide', {
    type: 'loop',
    drag: true,
    // focus: '0', // 從左邊對齊
    focus: 'center', // 從左邊對齊
    perPage: 3,
    gap: 42,
    padding: 0,
    speed: 2000,
    arrows: false,
    pagination: false,
    autoScroll: {
      speed: 1,
      pauseOnHover: false,
    },
    breakpoints: {
      768: { // 當 viewport <= 768px
        perPage: 1, // 改成顯示 1 張
        focus: 'center',
        gap: 52
      },
      390: {
        gap: 35
      }
    }
  });
  splide.mount(window.splide.Extensions);


  //Swiper
  var infoSwiper = void 0;
  function initInfoSwiper() {
    var isMobile = window.innerWidth <= 768;

    if (infoSwiper) {
      infoSwiper.destroy(true, true);
    }

    var config = {
      loop: true,
      grabCursor: true,
      observer: true,
      observeParents: true,
      pagination: {
        el: isMobile ? ".info-carousel__pagination.is-mobile" : ".info-carousel__pagination",
        clickable: true
      },
      on: {
        slideChange: function slideChange(swiper) {
          var index = swiper.realIndex;

          document.querySelectorAll(".info-carousel__step").forEach(function (el, i) {
            el.classList.toggle("is-active", i === index);
            el.classList.toggle("is-inactive", i !== index);
          });
        }
      }
    };

    if (isMobile) {
      // 手機設定
      config.slidesPerView = 1.1;
      // config.spaceBetween = 40;
      config.centeredSlides = false;
      config.autoplay = {
        delay: 5000,
        disableOnInteraction: false
      };
      config.breakpoints = {
        0: {
          slidesOffsetBefore: 12,
          spaceBetween: 12
        },
        768: {
          slidesOffsetBefore: 22,
          spaceBetween: 22
        },
        // 990: {
        //   slidesOffsetBefore: 30,
        //   spaceBetween: 30
        // }
      };
    } else {
      // 桌機設定
      config.effect = "fade";
      config.speed = 500;
      config.fadeEffect = { crossFade: true };
      config.autoplay = {
        delay: 5000,
        disableOnInteraction: false
      };
    }

    infoSwiper = new Swiper(".info-carousel__swiper", config);

    // 綁定互動事件（只在桌機啟用 hover 效果）
    var steps = document.querySelectorAll(".info-carousel__step");
    steps.forEach(function (el, i, all) {
      el.onmouseenter = null;
      el.onmouseleave = null;
      el.onclick = null;

      if (!isMobile) {
        el.addEventListener("mouseenter", function () {
          infoSwiper.autoplay.stop();
          infoSwiper.slideToLoop(i);

          all.forEach(function (step, idx) {
            step.classList.toggle("is-active", idx === i);
            step.classList.toggle("is-inactive", idx !== i);
            step.style.opacity = idx === i ? "1" : "0.6";
          });
        });

        el.addEventListener("mouseleave", function () {
          infoSwiper.autoplay.start();
          all.forEach(function (step) {
            step.style.opacity = "1";
          });
        });

        el.addEventListener("click", function () {
          infoSwiper.slideToLoop(i);
        });
      }
    });
  }
  // 初始化
  initInfoSwiper();
  // RWD resize 時自動重建
  window.addEventListener("resize", function () {
    clearTimeout(window._resizeTimer);
    window._resizeTimer = setTimeout(initInfoSwiper, 300);
  });
});
