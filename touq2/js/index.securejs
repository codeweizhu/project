document.addEventListener("DOMContentLoaded", () => {
  let tl = gsap.timeline({ repeat: -1, repeatDelay: 5 });
  tl.from("#title3", {
    scale: 0.3,
    opacity: 0,
    duration: 1,
    ease: "bounce.out"
  }, "start")
  .from("#title1", {
    scale: 0.3,
    opacity: 0,
    duration: 1,
    ease: "bounce.out"
  }, "start+=0.25")
  .from("#title2", {
    scale: 0.3,
    opacity: 0,
    duration: 1,
    ease: "bounce.out"
  }, "start+=0.5");
});

