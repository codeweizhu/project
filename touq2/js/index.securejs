// scrollAnim //
function scrollAnim() {
	var pageTop = $(document).scrollTop();
	var pageBottom = pageTop + $(window).height();
	var tags = $(".js-animate");
	var activeOffset = 30;

	tags.each(function (index) {
		if ($(this).offset().top < pageBottom - activeOffset) {
			$(this).addClass("js-animate--active");
		} else {
			$(this).removeClass("js-animate--active");
		}
	});
}
scrollAnim(); // init
$(document).on("scroll", scrollAnim);

//-loading
$(window).on("load", function () {
  $.Window = $(window);
  $.Body = $('body');
  $('body').css('visibility', 'visible');
  $(".loader").delay(500).fadeOut("slow");
  $("#overlayer").delay(500).fadeOut("slow");
})

//-輪播
new Splide('#mysplide', {
  type: 'loop',
  perPage: 2,
  drag: false,
  breakpoints: {
    768: {
      perPage: 1,
      drag: true,
    },
  },
}).mount();

//-toggle
$("#cash").on("click", function () {
  $(this).toggleClass("active");
  $("#cashdesc").slideToggle();
});
$("#certificate").on("click", function () {
  $(this).toggleClass("active");
  $("#certificatedesc").slideToggle();
});
$("#product").on("click", function () {
  $(this).toggleClass("active");
  $("#productdesc").slideToggle();
});

