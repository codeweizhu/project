//-star
document.addEventListener("DOMContentLoaded", () => {
  const stars = document.querySelectorAll(".star");
  stars.forEach(star => {
    function twinkle() {
      gsap.to(star, {
        opacity: 0,
        duration: Math.random() * 1 + 0.5,
        ease: "power1.inOut",
        onComplete: () => {
          gsap.set(star, { rotation: Math.random() * 360 });
          gsap.to(star, {
            opacity: Math.random() * 0.3 + 0.7, // 透明度回升
            scale: Math.random() * 0.4 + 0.8, // 大小變化
            duration: Math.random() * 2 + 2, // 閃爍時間
            ease: "power1.inOut",
            onComplete: twinkle,
          });
        }
      });
    }
    twinkle();
  });
});


//-錨點
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function (e) {
    e.preventDefault();
    const targetId = this.getAttribute('href').substring(1);
    const targetElement = document.getElementById(targetId);
    if (targetElement) {
      const headerOffset = 130;
      const elementPosition = targetElement.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({
        top: elementPosition - headerOffset,
        behavior: 'smooth'
      });
    }
  });
});

// header anchor link toggle menu
$("#header a.header-sec-link").on("click", function () {
  $("#header-toggle").removeClass("toggled");
  $("#header nav").removeClass("toggled");
});

// header menu setting
$("#header-toggle").on("click", function () {
  $(this).toggleClass("toggled");
  $("nav").toggleClass("toggled");
});

//-pop
$(".dawho-app-link").on("click", function (e) {
  // console.log(123);
  $("#qrcode-popup").fadeIn();
});
$(".close").on("click", function () {
  $("#qrcode-popup").fadeOut();
});



// 關閉popup
$('.popup-btns').on('click', () => {
  $('#popup-end').fadeOut();
});