'use strict';

$(document).ready(function () {

  // Loading
  $(window).on("load", function () {
    $.Window = $(window);
    $.Body = $('body');
    $('body').css('visibility', 'visible');
    $(".loader").delay(500).fadeOut("slow", function () {
      $("#overlayer").fadeOut("slow", function () {
        showLightboxIfNeeded();
      });
    });
  });

  // Lightbox
  function showLightboxIfNeeded() {
    var now = Math.floor(Date.now() / 1000);
    // УеГт«џтЁгтЉіТЎѓжќЊ 2026/3/31ућЪТЋѕ
    var announceEndTime = new Date("2026/03/31 23:59:59").getTime() / 1000;

    // УХЁжЂјтЁгтЉіТЎѓжќЊ Рєњ жА»уц║тйѕуфЌ
    if (now >= announceEndTime) {
      $('.lboxed').lightbox_me({
        centered: true,
        onLoad: function () {},
        overlayCSS: {
          background: 'black',
          opacity: 0.8,
        }
      });
    }
  }

  // жЌюжќЅТїЅжѕЋ
  $(".lboxed .close_x").on("click", function (e) {
    $(".lb_overlay").css({ display: "none" });
    $(".lboxed").css({ display: "none" });
  });
});

















function scrollAnim() {
	var pageTop = $(document).scrollTop();
	var pageBottom = pageTop + $(window).height();
	var tags = $(".js-animate");
	var activeOffset = 30;
	tags.each(function (index) {
		if ($(this).offset().top < pageBottom - activeOffset) {
			$(this).addClass("js-animate--active");
		} else {
			$(this).removeClass("js-animate--active");
		}
	});
}
scrollAnim(); // init
$(document).on("scroll", scrollAnim);


//жїеж╗ъ
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function (e) {
    e.preventDefault();
    const targetId = this.getAttribute('href').substring(1);
    const targetElement = document.getElementById(targetId);
    if (targetElement) {
      const headerOffset = 130;
      const elementPosition = targetElement.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({
        top: elementPosition - headerOffset,
        behavior: 'smooth'
      });
    }
  });
});



//nav
$("#header a.header-sec-link").on("click", function () {
  $("#header-toggle").removeClass("toggled");
  $("#header nav").removeClass("toggled");
});
$("#header-toggle").on("click", function () {
  $(this).toggleClass("toggled");
  $("nav").toggleClass("toggled");
});



// ========== Step Slider  ==========
$(window).on('load', function () {
  const $slider = $('#slide .slider');
  const $steps = $('#slide .list__item');
  const $imgs = $slider.find('img');
  let loadedCount = 0;
  //-ActiveТеБт╝ЈтѕЄТЈЏжѓЈУ╝»
  function activateStep(index) {
    $steps.removeClass('active').eq(index).addClass('active');
  }
  //-уХЂт«џУ╝фТњГУѕЄж╗ъТЊіУАїуѓ║
  function bindEvents() {
    $slider.on('afterChange', function (event, slick, currentSlide) {
      activateStep(currentSlide);
    });
    $steps.each(function (index) {
      $(this).on('mousedown', function () {
        $steps.removeClass('active');       // уФІтЇ│тѕЄТЈЏactive
        $(this).addClass('active');
        $slider.slick('slickGoTo', index);  // тѕЄТЈЏтѕ░т░ЇТЄЅslide
      });
    });
  }
  //-тѕЮтДІтїќ Slick У╝фТњГ
  function initSlider() {
    if ($slider.hasClass('slick-initialized')) return;
    $slider.slick({
      dots: true,
      infinite: true,
      arrows: false,
      speed: 300,
      slidesToShow: 1,
      autoplay: true,
      autoplaySpeed: 2500,
      adaptiveHeight: false
    });
    bindEvents();
  }
  //-ТфбТЪЦтюќуЅЄТў»тљдтЁежЃеУ╝ЅтЁЦ
  function checkIfAllImagesLoaded() {
    if (loadedCount >= $imgs.length) {
      initSlider();
    }
  }
  //-тюќуЅЄУ╝ЅтЁЦтЂхТИг
  $imgs.each(function () {
    if (this.complete && this.naturalHeight > 0) {
      loadedCount++;
    } else {
      $(this).on('load error', function () {
        loadedCount++;
        checkIfAllImagesLoaded();
      });
    }
  });
  checkIfAllImagesLoaded();
});
