//тИИУдІтЋЈжАї
$('.sec3__problem').click(function () {
  const $box = $(this).closest('.sec3__box');
  const $ans = $box.find('.sec3__answer');
  $('.sec3__answer').not($ans).slideUp();
  $('.sec3__problem').not(this).removeClass('is-open');
  $(this).toggleClass('is-open');
  $ans.slideToggle();
});


//Т│еТёЈС║ІжаЁ
$('.sec3__notice__toggle').on('click', function (event) {
  event.preventDefault();
  $('.notice').toggleClass('sec3__notice--active');
  $(this).siblings('.sec3__notice__content').slideToggle();
  $(this).toggleClass('is-open');
  // $('html, body').animate({
  //   scrollTop: $('.section__notice').offset().top
  // }, 300);
});




//star
const stars = [
  ".sec2__star1",
  ".sec2__star2",
  ".sec2__star3",
  ".sec2__star4",
  ".sec2__star5"
];
stars.forEach((selector, i) => {
  gsap.fromTo(selector,
    { opacity: 0 },
    {
      opacity: 1,
      duration: 1,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut",
      delay: i * 0.3
    }
  );
});

//kv
document.addEventListener("DOMContentLoaded", () => {
  let tl = gsap.timeline({ delay: 1 });

  tl.from(".sec1__screen", {
    opacity: 0,
    y: -300,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.4")
  .from(".sec1__circleUS", {
    opacity: 0,
    y: -100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.3")
  .from(".sec1__circleCNY", {
    opacity: 0,
    y: -100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.6")
  .from(".sec1__title1", {
    opacity: 0,
    y: -100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.6")
  .from(".sec1__title2", {
    opacity: 0,
    y: -100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.5")
  .from(".sec1__title3", {
    opacity: 0,
    y: -100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.5")
  .from(".sec1__desc", {
    opacity: 0,
    y: 100,
    duration: 0.8,
    ease: "power3.out",
  }, "-=0.4")
  .add(floating, "-=1");
});

//float
function floating() {
  const floatTargets = document.querySelectorAll('.sec1__circle');
  floatTargets.forEach((el, i) => {
    // тѕЮтДІУеГт«џ
    gsap.set(el, {
      y: 300,
      opacity: 0,
    });

    const tl = gsap.timeline({
      delay: 0.1 * i,
      onComplete: () => {
        // уггС║їТ«х№╝џТх«тІЋтІЋуЋФ
        const duration = gsap.utils.random(4, 7);
        const x = gsap.utils.random(-20, 20);
        const y = gsap.utils.random(-30, -10);
        const rotate = gsap.utils.random(-5, 5);
        gsap.to(el, {
          x,
          y,
          rotation: rotate,
          duration,
          ease: "sine.inOut",
          repeat: -1,
          yoyo: true,
          delay: 0.2 * i,
        });
      }
    });

    tl.to(el, {
      y: 35,
      duration: 0.8,
      ease: "power2.out",
    });

    tl.to(el, {
      y: 0,
      opacity: 1,
      duration: 0.7,
      ease: "power2.out",
    });
  });
}


$(window).on('scroll', function () {

  var $nav = $('.nav');
  var $notice = $('[data-id="changeBtn"]');
  var isMoved = !$nav.parent().hasClass('wrapper');
  var noticeTop = $notice[0].getBoundingClientRect().top;
  var windowHeight = window.innerHeight;

  if (window.innerWidth > 768) {
    if (!$nav.parent().hasClass('wrapper')) {
      $nav.removeClass('is-static');
      $('.wrapper').append($nav);
    }
    return;
  }
  //уЋХ notice жђ▓тЁЦУдќуфЌСИІТќ╣ 100px тЁДТЎѓУДИуЎ╝ТЈњтЁЦ
  if (noticeTop < windowHeight && !isMoved) {
    $nav.addClass('is-static');
    $nav.detach().insertAfter($notice);
  }
  //УІЦ notice т░џТюфжђ▓тЁЦУдќуфЌ№╝ѕТѕќти▓уХЊжЏбжќІуЋФжЮбСИіТќ╣№╝ЅтЅЄжѓётјЪ
  if (noticeTop >= windowHeight && isMoved) {
    $nav.removeClass('is-static');
    $('.wrapper').append($nav);
  }
});
$(window).trigger('scroll');





